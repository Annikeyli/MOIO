#include <iostream>
#include <cmath>
#include <iomanip>
#include <string>
#include <locale.h>

using namespace std;

// f(x) = e^x + 1/x
double f(double x) {
    return exp(x) + 1.0 / x;
}

void goldenSection(double a0, double b0, double l) {
    //(3-sqrt5)/2
    const double phi = (3.0 - sqrt(5.0)) / 2.0; 
        
    cout << "Функция: f(x) = e^x + 1/x\n";
    cout << "Начальный интервал: [" << a0 << "; " << b0 << "]\n";
    cout << "Точность: l = " << l << "\n";
   
    // ШАГ 1: Задать начальный интервал неопределенности L0 = [a0, b0], точность l > 0
    cout << "ШАГ 1: Задан начальный интервал неопределенности L0 = [" << a0 << ", " << b0 << "], точность l = " << l << "\n\n";

    // ШАГ 2: Положить k = 0
    int k = 0;
    cout << "ШАГ 2: Положить k = " << k << "\n\n";

    double a = a0;
    double b = b0;

    // ШАГ 3: Вычислить y0 и z0
    double y = a + phi * (b - a);
    double z = a + b - y;

    cout << "ШАГ 3: Вычислить y0 и z0\n";
    cout << "   y0 = a0 + (3-sqrt5)/2 * (b0 - a0) = " << a0 << " + " << phi << " * (" << b0 << " - " << a0 << ") = " << y << "\n";
    cout << "   z0 = a0 + b0 - y0 = " << a0 << " + " << b0 << " - " << y << " = " << z << "\n\n";

    // ШАГ 4: Вычислить f(yk), f(zk)
    double fy = f(y);
    double fz = f(z);

    cout << "ШАГ 4: Вычислить f(y0), f(z0)\n";
    cout << "   f(y0) = f(" << y << ") = e^" << y << " + 1/" << y << " = " << fy << "\n";
    cout << "   f(z0) = f(" << z << ") = e^" << z << " + 1/" << z << " = " << fz << "\n\n";

    double delta = b - a;
    
    // ШАГ 5 и 6 
    while (delta > l) {
        cout << "Итерация k = " << k << "\n";
        cout << "Текущий интервал: [" << a << ", " << b << "] \n";
        cout << "Точки: y = " << y << ", z = " << z << "\n";
        cout << "Значения: f(y) = " << fy << ", f(z) = " << fz << "\n\n";

        // ШАГ 5: Сравнить f(yk) и f(zk)
        cout << "ШАГ 5: Сравнить f(yk) и f(zk)\n";
        cout << "   f(y) = " << fy << ", f(z) = " << fz << "\n";

        if (fy <= fz) {
            cout << "   Так как f(y) <= f(z), то:\n";

            // Случай а
            double a_old = a;
            double b_old = b;
            double y_old = y;

            a = a; 
            b = z; 

            cout << "   a_{k+1} = a_k = " << a << "\n";
            cout << "   b_{k+1} = z_k = " << b << "\n\n";

            // Новые точки
            z = y; 
            fz = fy;
            y = a + b - y_old; 
            fy = f(y);

            cout << "   y_{k+1} = a_{k+1} + b_{k+1} - y_k = " << a << " + " << b << " - " << y_old << " = " << y << "\n";
            cout << "   z_{k+1} = y_k = " << z << "\n\n";
        }
        else {
            cout << "   Так как f(y) > f(z), то:\n";

            // Случай б
            double a_old = a;
            double b_old = b;
            double z_old = z;

            a = y; 
            b = b; 

            cout << "   a_{k+1} = y_k = " << a << "\n";
            cout << "   b_{k+1} = b_k = " << b << "\n\n";

            // Новые точки
            y = z; 
            fy = fz;
            z = a + b - z_old; 
            fz = f(z);

            cout << "   y_{k+1} = z_k = " << y << "\n";
            cout << "   z_{k+1} = a_{k+1} + b_{k+1} - z_k = " << a << " + " << b << " - " << z_old << " = " << z << "\n\n";
        }

        // ШАГ 4(k) : Вычислить f(y_{k+1}), f(z_{k+1})
        cout << "ШАГ 4(k): Вычислить f(y_{k+1}), f(z_{k+1})\n";
        cout << "   f(y_{k+1}) = f(" << y << ") = " << fy << "\n";
        cout << "   f(z_{k+1}) = f(" << z << ") = " << fz << "\n\n";

        // ШАГ 6: Вычислить d = |a_{k+1} - b_{k+1}| и проверить условие окончания
        delta = abs(b - a);
        cout << "ШАГ 6: Вычислить d = |a_{k+1} - b_{k+1}| \n";
        cout << "   d = |a_{k+1} - b_{k+1}| = |" << a << " - " << b << "| = " << delta << "\n";

        if (delta <= l) {
            cout << "   d <= l (" << delta << " <= " << l << ") -> процесс поиска завершается\n\n";
        }
        else {
            cout << "   d > l (" << delta << " > " << l << ") -> положить k = k + 1 и перейти к шагу 4\n\n";
        }

        k++; 
    }
        
    cout << "Результат:\n";
    cout << "Процесс поиска завершен, так как d = " << delta << " <= l = " << l << "\n";
    cout << "Последний интервал: [" << a << ", " << b << "]\n";

    double x_star = (a + b) / 2.0;
    
    cout << "В качестве приближенного решения можно взять середину последнего интервала:\n";
    cout << "   x* = (a_{k+1} + b_{k+1})/2 = (" << a << " + " << b << ")/2 = " << x_star << "\n";           
}

int main() {
    setlocale(LC_ALL, "Russian");
    double a0 = 0.5;
    double b0 = 1.1;
    double l = 0.1; 

    goldenSection(a0, b0, l);

    return 0;
}
